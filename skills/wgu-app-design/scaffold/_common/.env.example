# Supabase project — share with the rest of the subdomain apps
# so a single Google sign-in covers everything.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — used server-side for RLS-bypassing writes
# (usage_events, app_health, avatar uploads).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Smartsheet API token — used by master-roster and master-profile
# to read/write the Members and App Access sheets.
SMARTSHEET_API_TOKEN=YOUR-SMARTSHEET-TOKEN

# Cron secret — Vercel injects this as Bearer <CRON_SECRET> on
# scheduled health-check calls. Leave blank to disable auth.
CRON_SECRET=YOUR-CRON-SECRET

# Auth cookie domain — set to .yourdomain.com in production so a
# single sign-in covers all subdomains. Leave blank in local dev.
AUTH_COOKIE_DOMAIN=
